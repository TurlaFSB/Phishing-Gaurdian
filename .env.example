# ============================================================
# PHISHING GUARDIAN — ENVIRONMENT VARIABLES
# Copy this file to .env: cp .env.example .env
# Fill in your FREE API keys (all optional!)
# ============================================================

# --- APPLICATION ---
APP_NAME=Phishing Guardian
APP_VERSION=1.0.0
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# --- SECURITY ---
SECRET_KEY=change-this-to-a-random-string-64-chars-long
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# --- VIRUSTOTAL (Free: 500 req/day) ---
# Sign up: https://www.virustotal.com/gui/join-us
VT_API_KEY=

# --- ABUSEIPDB (Free: 1000 checks/day) ---
# Sign up: https://www.abuseipdb.com/register
ABUSEIPDB_API_KEY=

# --- GOOGLE SAFE BROWSING (Free: 10,000 req/day) ---
# Sign up: https://console.cloud.google.com
# Enable Safe Browsing API, create API key
GSB_API_KEY=

# --- URLSCAN (Free: no key needed) ---
# Leave blank — works without authentication
URLSCAN_API_KEY=

# --- RATE LIMITING ---
RATE_LIMIT_PER_MINUTE=30

# --- CACHE ---
CACHE_ENABLED=true
CACHE_TTL_HOURS=24

# --- DATABASE ---
DATABASE_URL=sqlite+aiosqlite:///./data/db/phishing_guardian.db

# --- LOGGING ---
LOG_LEVEL=INFO
LOG_FILE=logs/app.log